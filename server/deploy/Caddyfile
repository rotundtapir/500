{
	email {$ACME_EMAIL}
	# First bring-up only: uncomment to use Let's Encrypt staging while DNS/config is being sorted,
	# so a fumble can't burn the production certificate rate limit. Comment out and
	# `docker compose restart caddy` once a staging cert issues end to end.
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

{$SERVER_DOMAIN} {
	encode gzip

	# Admin + metrics are for on-box use only (docker compose exec / curl over SSH); never expose them.
	respond /admin* 403
	respond /metrics 403

	# Caddy proxies WebSocket upgrades transparently and does not time out established streams, so
	# long-lived game sockets are safe with no extra config. It sets X-Forwarded-For for the server.
	reverse_proxy server:8080
}
